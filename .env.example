# Database Configuration (Neon PostgreSQL)
DATABASE_URL=postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/hibiscus_airport?sslmode=require

# Stripe Payment
STRIPE_SECRET_KEY=sk_test_xxxxx

# Twilio SMS
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE_NUMBER=+1234567890

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Google Calendar OAuth
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_CALENDAR_ID=primary
BACKEND_URL=https://hibiscustoairport-backend.onrender.com

# Email — Mailgun
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.bookaride.co.nz
SENDER_EMAIL=noreply@bookaride.co.nz
ADMIN_EMAIL=bookings@bookaride.co.nz

# Application URLs
FRONTEND_URL=https://hibiscustoairport.co.nz
PUBLIC_DOMAIN=https://hibiscustoairport.co.nz

# API Keys
AVIATIONSTACK_API_KEY=xxxxx

# JWT Secret (auto-generated if not set, but should be stable in production)
JWT_SECRET_KEY=your-secure-jwt-secret

# Admin initial password (used when no admin exists yet)
ADMIN_INIT_PASSWORD=change-me-on-first-login

# CORS origins (comma-separated)
CORS_ORIGINS=https://hibiscustoairport.co.nz

# Optional: Admin API Key for backend admin routes
ADMIN_API_KEY=your-secure-admin-key

# Port (set by Render automatically in deployment)
PORT=10000
