# Backend API URL — leave empty for same-origin (Vercel serverless)
# Set to http://localhost:8000 for local backend development
# REACT_APP_BACKEND_URL=http://localhost:8000

# Google Maps API Key
REACT_APP_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Optional: Emergency owner access code (for bypassing normal login)
# REACT_APP_ADMIN_OWNER_CODE=your-secure-owner-code
